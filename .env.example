# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit real secrets.

# Required: get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Claude model (latest Sonnet)
CLAUDE_MODEL=claude-sonnet-4-6

# Where ChromaDB persists vectors on disk
CHROMA_PATH=.chroma

# Where the ingestion script reads source documents from.
# The repo includes a sparse-checkout of the public PostHog handbook here.
DOCS_PATH=docs/posthog/contents/handbook

# Local embedding model (downloads ~420MB the first time).
# Tradeoff vs all-MiniLM-L6-v2: ~5x larger, ~17 percentage-point higher hit@8 in our eval.
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# How many chunks to retrieve per query
TOP_K=8
