# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit real secrets.

# Required: get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Claude model (latest Sonnet)
CLAUDE_MODEL=claude-sonnet-4-6

# Where ChromaDB persists vectors on disk
CHROMA_PATH=.chroma

# Where the ingestion script reads source documents from
DOCS_PATH=docs/hr

# Local embedding model (downloads ~90MB the first time)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# How many chunks to retrieve per query
TOP_K=4
